# 镜核 (Mirror Core) 环境变量配置
# 复制此文件为 .env 并填写真实值

# === AI 提供商 ===
# 提供商类型: openai-compat | anthropic-compat | deepseek | glm
MIRROR_AI_PROVIDER_TYPE=openai-compat
# API 地址
MIRROR_AI_PROVIDER_BASE_URL=https://api.openai.com/v1
# API 密钥（必填）
MIRROR_AI_PROVIDER_API_KEY=
# 对话模型
MIRROR_AI_PROVIDER_MODEL=gpt-4o
# 嵌入模型（用于记忆向量检索）
MIRROR_AI_PROVIDER_EMBED_MODEL=text-embedding-3-small
# 备用提供商类型（当主提供商不可用时）
# MIRROR_AI_PROVIDER_FALLBACK_TYPE=deepseek

# === 运行模式 ===
# 日志级别: DEBUG | INFO | WARNING | ERROR
# MIRROR_LOG_LEVEL=INFO

# === Web 服务 ===
# 监听地址
# MIRROR_HOST=0.0.0.0
# 监听端口
# MIRROR_PORT=8000
